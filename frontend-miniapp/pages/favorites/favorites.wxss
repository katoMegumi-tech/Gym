.container {
  padding: 24rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: white;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}

.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-weight: bold;
}

.favorite-list {
  display: flex;
  flex-direction: column;
}

.favorite-item {
  background: white;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
  border: 1rpx solid #eef1f5;
}

.item-content {
  display: flex;
  align-items: flex-start;
}

.item-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 14rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.item-icon {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  color: #0a8f45;
  background: #eaf8ef;
}

.item-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  font-size: 24rpx;
  color: #999;
}

.item-arrow {
  font-size: 40rpx;
  color: #c0c4cc;
  margin-left: 12rpx;
  line-height: 1;
}

.item-action {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.remove-btn {
  background: #ff4d4f;
  color: white;
  border: none;
  border-radius: 24rpx;
  padding: 0 24rpx;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.empty-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #bbb;
}
