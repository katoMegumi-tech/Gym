<view class="container">
  <view class="banner">
    <text class="banner-title">体育馆场地预约</text>
    <text class="banner-subtitle">随时随地，轻松预约</text>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索场馆名称或地址" 
           value="{{searchKeyword}}" 
           bindinput="onSearchInput"
           bindconfirm="onSearch" />
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 公告轮播 -->
  <view class="notice-section" wx:if="{{announcements.length > 0}}">
    <view class="notice-icon">📢</view>
    <swiper class="notice-swiper" autoplay circular vertical interval="3000">
      <swiper-item wx:for="{{announcements}}" wx:key="id" bindtap="goToAnnouncement" data-item="{{item}}">
        <text class="notice-text">{{item.title}}</text>
      </swiper-item>
    </swiper>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">热门场馆</text>
      <view class="section-more" bindtap="goToVenueList">更多 ></view>
    </view>
    <scroll-view scroll-x class="venue-scroll">
      <view class="venue-item" wx:for="{{venues}}" wx:key="id" bindtap="goToVenue" data-id="{{item.id}}">
        <view class="venue-image" wx:if="{{!item.coverImage}}"></view>
        <image class="venue-image" wx:else src="{{item.coverImage}}" mode="aspectFill" />
        <view class="venue-name">{{item.name}}</view>
        <view class="venue-status-tag {{item.status === 'OPEN' ? 'open' : ''}}">
          {{item.status === 'OPEN' ? '营业中' : '休息中'}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-title">运动类型</view>
    <view class="sport-grid">
      <view class="sport-item" wx:for="{{sportTypes}}" wx:key="type" bindtap="goToSport" data-type="{{item.type}}">
        <text class="sport-icon">{{item.icon}}</text>
        <text class="sport-name">{{item.name}}</text>
      </view>
    </view>
  </view>
</view>
