<view class="container">
  <view class="tabs">
    <view class="tab {{activeTab === 'VENUE' ? 'active' : ''}}" bindtap="switchTab" data-tab="VENUE">
      收藏场馆
    </view>
    <view class="tab {{activeTab === 'COURT' ? 'active' : ''}}" bindtap="switchTab" data-tab="COURT">
      收藏场地
    </view>
  </view>

  <view class="favorite-list">
    <view class="favorite-item" wx:for="{{favorites}}" wx:key="id">
      <view class="item-content" bindtap="goToDetail" data-type="{{activeTab}}" data-id="{{item.targetId}}">
        <view class="item-cover">
          <image wx:if="{{item.cover}}" class="cover-img" mode="aspectFill" src="{{item.cover}}" />
          <view wx:else class="item-icon">
            <text wx:if="{{activeTab === 'VENUE'}}">🏢</text>
            <text wx:else>🏀</text>
          </view>
        </view>
        <view class="item-info">
          <view class="item-top">
            <view class="item-title">{{item.title}}</view>
            <view class="item-status">{{item.statusText}}</view>
          </view>
          <view class="item-desc">{{item.subtitle}}</view>
        </view>
        <view class="item-arrow">›</view>
      </view>
      <view class="item-action">
        <button class="remove-btn" size="mini" bindtap="removeFavorite" data-id="{{item.id}}">
          取消收藏
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:if="{{!loading && favorites.length === 0}}" class="empty">
    <view class="empty-icon">⭐</view>
    <view class="empty-text">暂无收藏</view>
    <view class="empty-sub">去场馆和场地页面收藏你喜欢的项目</view>
  </view>
</view>
